@startuml
title Botica POS MediZano - Secuencia principal
actor Cajero
participant "Frontend Angular" as FE
participant "API REST" as API
participant "Auth/JWT" as Auth
participant "Servicio Ventas" as Ventas
participant "Servicio Inventario" as Inventario
participant "Servicio Pagos" as Pagos
database "PostgreSQL" as DB
participant "Generador PDF" as PDF

Cajero -> FE : inicia sesion
FE -> API : POST /api/auth/login
API -> Auth : validar credenciales
Auth -> DB : consultar usuario y rol
DB --> Auth : usuario valido
Auth --> API : JWT y permisos
API --> FE : sesion iniciada

Cajero -> FE : busca medicamento
FE -> API : GET /api/medicines?query
API -> Auth : validar JWT
API -> DB : consultar productos activos
DB --> API : medicamentos disponibles
API --> FE : resultados de busqueda

Cajero -> FE : agrega productos y confirma venta
FE -> API : POST /api/billing/sales
API -> Auth : validar rol de cajero
API -> Ventas : crear venta solicitada
Ventas -> Inventario : validar stock por lote
Inventario -> DB : consultar lote disponible
DB --> Inventario : stock y vencimiento

alt stock disponible
  Inventario --> Ventas : stock reservado
  Ventas -> Ventas : calcular subtotal, IGV y total
  Ventas -> Pagos : registrar metodo y monto pagado

  alt pago aprobado
    Pagos --> Ventas : pago confirmado
    Ventas -> DB : guardar venta, detalle y pago
    Ventas -> Inventario : descontar stock
    Inventario -> DB : actualizar lote
    Ventas -> PDF : generar comprobante
    PDF --> Ventas : comprobante PDF
    Ventas --> API : venta registrada
    API --> FE : total, vuelto y comprobante
    FE --> Cajero : muestra venta finalizada
  else pago rechazado
    Pagos --> Ventas : pago no aprobado
    Ventas --> API : venta no registrada
    API --> FE : mostrar error de pago
    FE --> Cajero : solicita otro metodo de pago
  end
else stock insuficiente
  Inventario --> Ventas : stock no disponible
  Ventas --> API : venta rechazada
  API --> FE : mostrar alerta de stock
  FE --> Cajero : corregir cantidades
end
@enduml
