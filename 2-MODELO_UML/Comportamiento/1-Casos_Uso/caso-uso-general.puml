@startuml
left to right direction
title Botica POS MediZano - Casos de uso
actor Cajero
actor Cliente
actor "Encargado de almacen" as Almacen
actor Administrador
actor "Gerente / Analista" as Gerente
rectangle "Botica POS MediZano" {
  usecase "Buscar medicamento" as UC1
  usecase "Registrar venta" as UC2
  usecase "Calcular IGV y total" as UC3
  usecase "Registrar pago" as UC4
  usecase "Generar comprobante PDF" as UC5
  usecase "Gestionar medicamentos" as UC6
  usecase "Controlar lotes y stock" as UC7
  usecase "Consultar reportes" as UC8
  usecase "Gestionar usuarios y roles" as UC9
}
Cajero --> UC1
Cajero --> UC2
Cajero --> UC4
Cliente --> UC5
Almacen --> UC6
Almacen --> UC7
Gerente --> UC8
Administrador --> UC9
UC2 ..> UC3 : incluye
UC2 ..> UC5 : incluye
@enduml
