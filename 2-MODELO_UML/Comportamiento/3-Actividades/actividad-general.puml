@startuml
title Botica POS MediZano - Actividad operativa
start
:Iniciar sesion;
:Seleccionar modulo;
if (Ventas?) then (si)
  :Buscar medicamento;
  :Agregar al comprobante;
  :Calcular subtotal, IGV y total;
  :Registrar pago;
  :Generar PDF;
  :Descontar stock;
else (no)
  if (Inventario o medicamentos?) then (si)
    :Registrar producto o lote;
    :Actualizar existencias;
    :Revisar alertas de stock y vencimiento;
  else (reportes/usuarios)
    :Consultar indicadores o administrar usuarios;
    :Registrar auditoria;
  endif
endif
:Mostrar resultado;
stop
@enduml
