@startuml
title Botica POS MediZano - Despliegue
node "Cliente" { artifact "Navegador web" as Browser }
node "Servidor Web" { artifact "Angular 17 build" as Angular }
node "Servidor API" { artifact "Spring Boot 3.2 / Java 17" as API; artifact "iText PDF" as PDF }
database "PostgreSQL 14+" as DB
node "Almacen de comprobantes" { artifact "Comprobantes PDF" as Files }
Browser --> Angular : HTTPS
Angular --> API : REST / JSON
API --> DB : JDBC
API --> PDF : Java API
PDF --> Files : guarda PDF
@enduml
