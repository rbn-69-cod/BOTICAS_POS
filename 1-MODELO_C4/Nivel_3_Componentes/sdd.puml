@startuml
!include <C4/C4_Component>
title Botica POS Peru - Componentes Backend
Container_Boundary(api, "API REST Spring Boot") {
  Component(auth, "AuthController", "REST", "Login y JWT")
  Component(billing, "BillingController", "REST", "Ventas, pagos y comprobantes")
  Component(medicine, "MedicineController", "REST", "Medicamentos")
  Component(batch, "BatchController", "REST", "Lotes y stock")
  Component(report, "ReportController", "REST", "Reportes")
  Component(user, "UserController", "REST", "Usuarios y roles")
  Component(audit, "AuditLogController", "REST", "Auditoria")
  Component(sec, "Security Layer", "Spring Security", "Filtros JWT y permisos")
  Component(secConfig, "SecurityConfig", "Singleton Bean", "Configuracion unica de rutas, filtros y permisos")
  Component(jwt, "JwtTokenProvider", "Singleton Bean", "Generacion y validacion de tokens JWT")
  Component(service, "Service Layer", "Spring Services", "Reglas de negocio")
  Component(repo, "Repository Layer", "Spring Data JPA", "Persistencia")
  Component(pdf, "PDF Generator", "iText / Singleton Bean", "Comprobantes PDF")
}
ContainerDb(db, "PostgreSQL", "Base de datos", "Datos operativos")
Rel(auth, sec, "Autentica")
Rel(sec, secConfig, "Aplica configuracion")
Rel(sec, jwt, "Valida token")
Rel(billing, service, "Procesa ventas")
Rel(medicine, service, "Valida productos")
Rel(batch, service, "Actualiza stock")
Rel(report, service, "Consolida indicadores")
Rel(user, service, "Gestiona usuarios")
Rel(audit, service, "Registra actividad")
Rel(service, repo, "Consulta y persiste")
Rel(service, pdf, "Genera comprobantes")
Rel(repo, db, "JPA / JDBC")
@enduml
