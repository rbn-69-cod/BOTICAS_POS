@startuml
!include <C4/C4_Container>
title Botica POS Peru - Contenedores
Person(cajero, "Cajero", "Atiende ventas")
Person(admin, "Administrador", "Gestiona usuarios")
Person(almacen, "Encargado de almacen", "Gestiona stock")
Person(gerente, "Gerente / Analista", "Consulta reportes")
System_Boundary(sistema, "Botica POS MediZano") {
  Container(web, "Aplicacion Web", "Angular 17 / TypeScript", "Interfaz de operacion")
  Container(api, "API REST", "Spring Boot 3.2 / Java 17", "Reglas de negocio y seguridad JWT")
  ContainerDb(db, "Base de datos", "PostgreSQL", "Ventas, medicamentos, lotes, usuarios y auditoria")
  Container(pdf, "Servicio PDF", "iText PDF", "Comprobantes")
  Container(swagger, "Swagger UI", "Springdoc OpenAPI", "Documentacion de API")
}
Rel(cajero, web, "Registra ventas")
Rel(admin, web, "Administra usuarios")
Rel(almacen, web, "Controla inventario")
Rel(gerente, web, "Ve reportes")
Rel(web, api, "REST / JSON")
Rel(api, db, "JPA / JDBC")
Rel(api, pdf, "Genera comprobantes")
Rel(api, swagger, "Publica endpoints")
@enduml
